{
  "name": "container-desktop",
  "desktopName": "container-desktop",
  "title": "Container Desktop",
  "version": "5.3.18",
  "author": "Ionut Stoica",
  "description": "Container Desktop",
  "main": "build/5.3.18/main.cjs",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "biome": "biome",
    "node": "node",
    "electron": "electron",
    "cross-env": "cross-env",
    "dev": "cross-env ENVIRONMENT=development node support/watch.mjs",
    "prod:build": "cross-env ENVIRONMENT=production yarn build",
    "prod": "yarn prod:build && cross-env ENVIRONMENT=production node support/prod.mjs",
    "build": "yarn build:main && yarn build:preload && yarn build:renderer",
    "build:main": "vite build --mode=production --config vite.config.main.mjs",
    "build:preload": "vite build --mode=production --config vite.config.preload.mjs",
    "build:renderer": "vite build --mode=production --config vite.config.renderer.mjs",
    "build:website": "eleventy",
    "dev:website": "eleventy --serve --port=8088",
    "demo:record": "node support/demoReplay.mjs --mode=dev",
    "screenshots": "node support/screenshots.mjs --mode=dev",
    "bundle": "cross-env DEBUG=electron-builder electron-builder --config electron-builder-config.cjs",
    "release": "yarn build && yarn bundle",
    "release:github": "node support/release-artifacts.cjs publish",
    "package:mac_arm": "cross-env DEBUG=electron-builder electron-builder --publish never --macos --arm64 --config electron-builder-config.cjs",
    "package:win_x86": "cross-env DEBUG=electron-builder electron-builder --publish never --windows --x64 --config electron-builder-config.cjs",
    "package:linux_x86": "cross-env DEBUG=electron-builder electron-builder --publish never --linux --x64 --config electron-builder-config.cjs",
    "package:linux_arm": "cross-env DEBUG=electron-builder electron-builder --publish never --linux --arm64 --config electron-builder-config.cjs",
    "check-types": "tsc",
    "lint": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "lint:check": "biome check ./src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:live": "vitest run --config vitest.live.config.mts",
    "test:ui": "vitest run --config vitest.ui.config.mts",
    "watch": "node support/watch.mjs",
    "postinstall": "cross-env ELECTRON_RUN_AS_NODE=1 yarn electron support/update-electron-vendors.mjs && node support/patch-node-modules.mjs"
  },
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@ai-sdk/anthropic": "4.0.4",
    "@ai-sdk/openai": "4.0.4",
    "@ai-sdk/openai-compatible": "3.0.2",
    "@blueprintjs/core": "6.17.0",
    "@blueprintjs/icons": "6.12.0",
    "@blueprintjs/select": "6.3.1",
    "@csstools/normalize.css": "12.1.1",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-virtual": "3.14.5",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "ai": "7.0.9",
    "axios": "1.18.1",
    "dayjs": "1.11.21",
    "deepmerge": "4.3.1",
    "electron-log": "5.4.4",
    "eventemitter3": "5.0.4",
    "file-saver": "2.0.5",
    "fix-path": "5.0.0",
    "i18next": "26.3.4",
    "ipaddr.js": "2.4.0",
    "monaco-editor": "0.55.1",
    "path-to-regexp": "8.4.2",
    "pretty-bytes": "7.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-fast-compare": "3.2.2",
    "react-helmet-async": "3.0.0",
    "react-hook-form": "7.80.0",
    "react-i18next": "17.0.8",
    "react-markdown": "10.1.0",
    "react-split-pane": "3.2.0",
    "remark-gfm": "4.0.1",
    "semver": "7.8.5",
    "ssh-config": "5.1.0",
    "undici": "8.5.0",
    "usehooks-ts": "3.1.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.6",
    "@biomejs/biome": "2.5.1",
    "@faker-js/faker": "10.5.0",
    "@rrweb/record": "2.1.0",
    "@tanstack/react-query-devtools": "5.101.2",
    "@types/node": "26.0.1",
    "@types/nunjucks": "3.2.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "mime-types": "3.0.2",
    "playwright-core": "1.61.1",
    "postcss": "8.5.16",
    "rrweb": "2.1.0",
    "svgo": "4.0.1",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "vite-plugin-checker": "0.14.4",
    "vite-plugin-ejs": "2.0.0",
    "vite-plugin-static-copy": "4.1.1",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.9",
    "xml2js": "0.6.2"
  },
  "optionalDependencies": {
    "dmg-license": "1.0.11"
  },
  "resolutions": {
    "@11ty/eleventy/gray-matter/js-yaml": "4.2.0",
    "dompurify": "3.4.11",
    "electron/@electron/get/undici": "7.28.0",
    "lodash": "4.18.1",
    "fast-uri": "3.1.2",
    "@xmldom/xmldom": "0.8.13",
    "tmp": "0.2.7"
  },
  "repository": "https://github.com/iongion/container-desktop.git"
}
