# Live connectivity test targets — copy to targets.env (gitignored) and fill in your machines.
# Run:  CONTAINER_DESKTOP_TEST_TARGETS=linux_vm yarn test:live   (omit the var to run every ENABLED target)
# Any CDT_TARGET_* value can also be overridden by a real environment variable (env wins over the file).
# Target ids use underscores (not hyphens) so they are valid as both dotenv keys and shell env vars.
#
# Per target <ID>:
#   _ENABLED        true|false              run it when no explicit selection is given
#   _OS             Linux|Darwin|Windows_NT the OS where the container-desktop client runs
#   _HOSTS          comma list of ContainerEngineHost ids this machine can exercise, e.g.
#                   podman.native, docker.native, podman.virtualized.wsl, docker.virtualized.lima,
#                   podman.virtualized.vendor, podman.remote, docker.remote
#   _PODMAN_SOCKET  unix socket path for podman.native       (e.g. /run/user/1000/podman/podman.sock)
#   _DOCKER_SOCKET  unix socket path for docker.native       (e.g. /var/run/docker.sock)
#   _SSH_HOST/_SSH_PORT/_SSH_USER/_SSH_KEY  for the *.remote (SSH) hosts
#   _WSL_DISTRO     distro name for *.virtualized.wsl        (e.g. Ubuntu)
#   _LIMA_INSTANCE  instance name for *.virtualized.lima     (e.g. default)
#   _APP_PATH       built release dir holding the relay exe  (Windows WSL/SSH only)

# --- Linux VM: native podman+docker, and reachable as an SSH remote ---
CDT_TARGET_LINUX_VM_ENABLED=false
CDT_TARGET_LINUX_VM_OS=Linux
CDT_TARGET_LINUX_VM_HOSTS=podman.native,docker.native,podman.remote,docker.remote
CDT_TARGET_LINUX_VM_PODMAN_SOCKET=/run/user/1000/podman/podman.sock
CDT_TARGET_LINUX_VM_DOCKER_SOCKET=/var/run/docker.sock
CDT_TARGET_LINUX_VM_SSH_HOST=192.168.122.10
CDT_TARGET_LINUX_VM_SSH_PORT=22
CDT_TARGET_LINUX_VM_SSH_USER=ion
CDT_TARGET_LINUX_VM_SSH_KEY=~/.ssh/id_ed25519

# --- Windows VM: Docker Desktop, WSL distros, and SSH remote ---
CDT_TARGET_WIN_VM_ENABLED=false
CDT_TARGET_WIN_VM_OS=Windows_NT
CDT_TARGET_WIN_VM_HOSTS=docker.virtualized.vendor,podman.virtualized.wsl,docker.virtualized.wsl,podman.remote,docker.remote
CDT_TARGET_WIN_VM_WSL_DISTRO=Ubuntu
CDT_TARGET_WIN_VM_SSH_HOST=192.168.122.20
CDT_TARGET_WIN_VM_SSH_USER=ion
CDT_TARGET_WIN_VM_SSH_KEY=~/.ssh/id_ed25519
CDT_TARGET_WIN_VM_APP_PATH=C:\\path\\to\\release

# --- macOS laptop: LIMA, Docker Desktop, and SSH remote ---
CDT_TARGET_MAC_ENABLED=false
CDT_TARGET_MAC_OS=Darwin
CDT_TARGET_MAC_HOSTS=podman.virtualized.lima,docker.virtualized.lima,docker.virtualized.vendor,podman.remote,docker.remote
CDT_TARGET_MAC_LIMA_INSTANCE=default
CDT_TARGET_MAC_SSH_HOST=192.168.122.30
CDT_TARGET_MAC_SSH_USER=ion
CDT_TARGET_MAC_SSH_KEY=~/.ssh/id_ed25519

# --- Docker Swarm sandbox (for swarm.live.test.ts) ---
# Point _DOCKER_SOCKET at the DISPOSABLE dind sandbox (support/swarm-sandbox.sh up | up-multi), NOT your
# primary daemon. Run:  CONTAINER_DESKTOP_TEST_TARGETS=swarm yarn test:live
CDT_TARGET_SWARM_ENABLED=false
CDT_TARGET_SWARM_OS=Linux
CDT_TARGET_SWARM_HOSTS=docker.native
CDT_TARGET_SWARM_DOCKER_SOCKET=./temp/swarm-sandbox/docker.sock
