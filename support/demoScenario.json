{
  "id": "container-desktop-demo",
  "title": "Container Desktop product walkthrough",
  "pitch": "A compact website demo for users comparing Container Desktop with Docker Desktop, Podman Desktop, Rancher Desktop, and other container UIs.",
  "engine": "podman",
  "viewport": { "width": 1068, "height": 718 },
  "output": "website-src/static/replays/container-desktop-demo.json",
  "baseTimestamp": 1735737600000,
  "screenHoldMs": 10000,
  "captureSettleMs": 250,
  "actionFocusMs": 2200,
  "actionPulseMs": 900,
  "actionResultMs": 3500,
  "navigationFocusMs": 2400,
  "navigationResultMs": 4200,
  "highlightPadding": 8,
  "steps": [
    {
      "keyword": "Given",
      "label": "Auto-detect",
      "text": "Container Desktop starts cleanly and auto-detects the mock Podman engine",
      "actions": [
        { "type": "waitReady" },
        { "type": "waitFor", "selector": "[data-screen=\"dashboard\"]" },
        { "type": "hover", "selector": "a[data-screen=\"dashboard\"]", "duration": 900 },
        { "type": "move", "x": 534, "y": 280, "duration": 1200, "hold": 600 }
      ],
      "hold": 6500
    },
    {
      "keyword": "When",
      "label": "Real workloads",
      "text": "opening a realistic inventory: LAMP, Redis, observability, workers, running, paused, and exited",
      "actions": [
        {
          "type": "click",
          "selector": "a[data-screen=\"containers\"]",
          "waitFor": "[data-container]",
          "minCount": 9,
          "duration": 1100,
          "resultMs": 600
        },
        { "type": "sidebar", "expanded": false, "hold": 300 },
        { "type": "hover", "selector": "[data-container=\"8a100000000000000000000000000004\"]", "duration": 1300, "hold": 700 }
      ],
      "hold": 8500
    },
    {
      "keyword": "And",
      "label": "Fast actions",
      "text": "using the action menu Docker users expect, without giving up Podman",
      "actions": [
        {
          "type": "pre",
          "pre": [
            {
              "action": "openRowActions",
              "rowSelector": "[data-container=\"8a100000000000000000000000000004\"]"
            }
          ]
        }
      ],
      "hold": 7000
    },
    {
      "keyword": "Then",
      "label": "Deep inspect",
      "text": "inspecting container configuration like an operator, not a marketing dashboard",
      "actions": [
        { "type": "key", "key": "Escape", "hold": 300 },
        { "type": "hover", "selector": "[data-container=\"8a100000000000000000000000000004\"]", "duration": 1000, "hold": 400 },
        {
          "type": "navigate",
          "route": "/screens/container/$containerId/inspect",
          "resolve": {
            "containerId": {
              "route": "/screens/containers",
              "selector": "[data-container=\"8a100000000000000000000000000004\"]",
              "attr": "data-container"
            }
          },
          "waitFor": "[data-table=\"container.inspect\"]"
        }
      ],
      "hold": 8500
    },
    {
      "keyword": "When",
      "label": "Security",
      "text": "checking image vulnerabilities from the same desktop instead of jumping tools",
      "actions": [
        {
          "type": "click",
          "selector": "a[data-screen=\"images\"]",
          "waitFor": "[data-image]",
          "minCount": 4,
          "duration": 1100
        },
        { "type": "hover", "selector": "[data-image]", "duration": 1200, "hold": 500 },
        {
          "type": "navigate",
          "route": "/screens/image/$imageId/security",
          "resolve": {
            "imageId": { "route": "/screens/images", "selector": "[data-image]", "attr": "data-image" }
          },
          "waitFor": "[data-table=\"image.scanning.report\"] tbody tr[data-severity]",
          "minCount": 2
        }
      ],
      "hold": 8500
    },
    {
      "keyword": "And",
      "label": "Podman-native",
      "text": "showing pods for production-style stacks that Docker-first tools usually flatten away",
      "actions": [
        {
          "type": "click",
          "selector": "a[data-screen=\"pods\"]",
          "waitFor": "[data-pod]",
          "minCount": 12,
          "duration": 1100
        },
        { "type": "hover", "selector": "[data-pod]", "duration": 1200, "hold": 600 }
      ],
      "hold": 9000
    },
    {
      "keyword": "Then",
      "label": "Any endpoint",
      "text": "managing local, SSH, WSL, and LIMA connections for both Podman and Docker from one place",
      "actions": [
        {
          "type": "click",
          "selector": "a[aria-label=\"Settings\"]",
          "waitFor": "tr[data-connection-id=\"mock.podman.system\"][data-connection-is-default=\"yes\"][data-connection-is-current=\"yes\"][data-connection-is-connected=\"yes\"]"
        },
        { "type": "wait", "ms": 250 }
      ],
      "hold": 8500
    }
  ]
}
