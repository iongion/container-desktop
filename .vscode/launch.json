{
  "version": "0.2.0",
  // "Debug All" is the entry point: it starts `yarn dev` (Vite dev server + Electron)
  // via the preLaunchTask, then attaches a debugger to BOTH processes. Breakpoints work
  // in the real TypeScript sources thanks to the dev build's sourcemaps.
  //   - Main process  -> Node inspector on 9229 (enabled by CONTAINER_DESKTOP_INSPECT)
  //   - Renderer      -> Chrome DevTools Protocol on 9222 (already exposed by watch.mjs)
  "configurations": [
    {
      // Dev with the system-tray widget auto-opened (`yarn dev:tray` sets
      // CONTAINER_DESKTOP_OPEN_TRAY=1, which main.ts honours in development only).
      // Runs the script in an integrated terminal; no debugger attach (use "Debug All" for that).
      "name": "Dev (tray widget)",
      "type": "node-terminal",
      "request": "launch",
      "command": "yarn dev:tray",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "order": 2
      }
    },
    {
      "name": "Attach Main Process",
      "type": "node",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9229,
      // watch.mjs kills + respawns Electron on every main-process change; reconnect.
      "restart": true,
      // Electron is launched with --inspect (not --inspect-brk), so don't stay paused.
      "continueOnAttach": true,
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/build/**/*.cjs"],
      "resolveSourceMapLocations": ["${workspaceFolder}/build/**", "!**/node_modules/**"],
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Attach Renderer Process",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "timeout": 60000,
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug All",
      "configurations": ["Attach Main Process", "Attach Renderer Process"],
      "preLaunchTask": "dev: electron + inspector",
      "stopAll": true,
      "presentation": {
        "order": 1
      }
    }
  ]
}
