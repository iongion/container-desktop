{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Container Desktop",
  "version": "6.0.0",
  "identifier": "com.iongion.container-desktop.tauri",
  "build": {
    "frontendDist": "../build/6.0.0",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "yarn tauri:serve"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Container Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 718,
        "decorations": false,
        "resizable": true,
        "center": true,
        "visible": false,
        "backgroundColor": "#171c26"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
